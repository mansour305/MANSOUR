# =============================================================================
# مواعيدك — Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env وأضف المفاتيح الحقيقية
# =============================================================================

# ── Supabase Configuration ──────────────────────────────────────────────────
# مطلوب للتشغيل في الإنتاج
# احصل على المفاتيح من: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co

VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxOTU3MzQ1MjAwfQ.example-key-here

# ── API Server (Optional) ───────────────────────────────────────────────────
# فقط إذا كان لديك خادم API منشور
# VITE_API_BASE_URL=https://your-api-server.vercel.app

# ── Data Source Mode (Optional) ────────────────────────────────────────────
# Options: "supabase" | "api" | "supabase_shadow"
# افتراضي: يكتشف تلقائياً
# VITE_DATA_SOURCE_MODE=supabase

# ── Web Push Notifications ──────────────────────────────────────────────────
# مطلوب لإشعارات "ذكرني" عند إغلاق التطبيق
# اتبع الخطوات أدناه لإنشاء مفاتيح VAPID:
# 
# 1. شغّل: npx web-push generate-vapid-keys
# 2. ستحصل على:
#    - VITE_VAPID_PUBLIC_KEY (آمن للعرض في الواجهة)
#    - VAPID_PRIVATE_KEY (سري، أضفه في Supabase Edge Functions)
# 3. أضف VITE_VAPID_PUBLIC_KEY هنا
# 4. أضف VAPID_PRIVATE_KEY في متغيرات Supabase Edge Function

VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── Demo Mode (Development Only) ──────────────────────────────────────────────
# اتركه فارغاً في الإنتاج
# هذا يسمح بتسجيل دخول تجريبي في وضع التطوير فقط

# VITE_DEMO_ADMIN_PASSWORD=your-demo-password-here

# =============================================================================
# للتشغيل:
# 1. أنشئ مشروع Supabase جديد
# 2. انسخ SQL من supabase-bootstrap.sql ونفّذه في Supabase SQL Editor
# 3. أضف المفاتيح أعلاه
# 4. لإنشاء مفاتيح VAPID للإشعارات: npx web-push generate-vapid-keys
# 5. شغّل: pnpm run dev
# =============================================================================