# Environment Configuration - PRODUCTION
# Update these values before deployment

# Server
PORT=3000
NODE_ENV=production

# JWT Configuration (REQUIRED - Generate a strong 32+ character secret)
JWT_SECRET=mawaeedak_production_secret_key_please_change_this
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./database.sqlite

# CORS (comma-separated origins)
CORS_ORIGIN=https://mawaeedak.com,https://admin.mawaeedak.com

# Admin Setup
ADMIN_EMAIL=admin@mawaeedak.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
