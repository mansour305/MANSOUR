## التعديل المطلوب

```tsx
import mawaeedakLogo from "@/assets/brand/mawaeedak-logo-new-transparent.png";

export function MawaeedakLogo({ compact = false }: { compact?: boolean }) {
  return (
    <div className="flex items-center justify-center" aria-label="مواعيدك">
      <img
        src={mawaeedakLogo}
        alt="مواعيدك"
        className="object-contain"
        style={{
          width: compact ? 170 : 240,
          height: compact ? 58 : 82,
        }}
      />
    </div>
  );
}
```
